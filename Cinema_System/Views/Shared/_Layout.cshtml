<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cinema_System</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-100 text-gray-800">

    <header class="bg-white shadow-sm">
        <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
            <a asp-controller="Home" asp-action="Index" class="text-lg font-bold text-indigo-600">
                Cinema_System
            </a>

            <ul class="flex items-center gap-6 text-sm font-medium">
                <li>
                    <a asp-controller="Home" asp-action="Index" class="text-gray-600 hover:text-indigo-600">Trang chủ</a>
                </li>
                <li>
                    <a asp-controller="Profile" asp-action="Index" class="text-gray-600 hover:text-indigo-600">Hồ sơ</a>
                </li>
            </ul>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="mt-10 border-t bg-white py-4 text-center text-sm text-gray-500">
        &copy; 2026 - Cinema_System
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>