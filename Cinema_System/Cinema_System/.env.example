# Sao chép file này thành .env rồi điền giá trị thật (file .env đã được gitignore).
# Password là App Password 16 ký tự của Gmail (Google Account > Security > App passwords).
EmailSettings__User=youremail@gmail.com
EmailSettings__Password=xxxxxxxxxxxxxxxx
EmailSettings__FromEmail=youremail@gmail.com

# Google OAuth (Google Cloud Console > APIs & Services > Credentials > OAuth client ID - Web).
# Authorized redirect URI cần thêm: https://localhost:7xxx/signin-google và http://localhost:5056/signin-google
GoogleSettings__ClientId=xxxxxxxx.apps.googleusercontent.com
GoogleSettings__ClientSecret=xxxxxxxxxxxxxxxx
