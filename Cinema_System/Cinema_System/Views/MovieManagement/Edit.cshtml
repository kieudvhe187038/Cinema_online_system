@model MovieFormViewModel
@{
    ViewData["Title"] = "Sửa Phim";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

@{
    const string fieldInput = "w-full px-3 py-2.5 border border-[#e0c0b2] rounded-lg bg-white text-sm box-border focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20";
    const string fieldLabel = "block font-semibold text-[#584237] mb-1.5 text-sm";
    const string fieldError = "block text-red-700 text-xs mt-1";
    const string card = "bg-white rounded-xl shadow-sm p-7 mb-5";
    const string sectionTitle = "font-bold text-base text-[#191c1d] mb-4 pb-2 border-b-2 border-[#edeeef]";
    const string fileInput = "w-full text-sm text-[#584237] border border-[#e0c0b2] rounded-lg p-2 cursor-pointer file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary file:text-white file:text-sm file:font-semibold hover:file:bg-primary-dark file:cursor-pointer";
}

<div class="max-w-[860px] mx-auto mb-8">
    <h1 class="font-head text-2xl font-extrabold text-[#191c1d] mb-6">Sửa Phim: @Model.Title</h1>

    <form method="post" action="@Url.Action("Edit", "MovieManagement", new { id = Model.Id })" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        @* Giữ lại đường dẫn file hiện tại nếu không upload file mới *@
        <input type="hidden" asp-for="PosterUrl" />
        <input type="hidden" asp-for="BannerUrl" />
        <input type="hidden" asp-for="TrailerUrl" />

        <div class="@card">
            <p class="@sectionTitle">Thông tin cơ bản</p>
            <div asp-validation-summary="ModelOnly" class="text-red-700 text-sm mb-4"></div>

            <div class="grid grid-cols-2 gap-x-5 gap-y-1">
                <div class="mb-3.5 col-span-2">
                    <label asp-for="Title" class="@fieldLabel"></label>
                    <input asp-for="Title" class="@fieldInput" />
                    <span asp-validation-for="Title" class="@fieldError"></span>
                </div>

                <div class="mb-3.5">
                    <label asp-for="Status" class="@fieldLabel"></label>
                    <select asp-for="Status" class="@fieldInput">
                        <option value="Coming Soon">Sắp chiếu</option>
                        <option value="Now Showing">Đang chiếu</option>
                        <option value="Stopped">Tạm ngừng</option>
                    </select>
                    <span asp-validation-for="Status" class="@fieldError"></span>
                </div>

                <div class="mb-3.5">
                    <label asp-for="AgeRating" class="@fieldLabel"></label>
                    <select asp-for="AgeRating" class="@fieldInput">
                        <option value="">-- Chọn --</option>
                        <option value="P">P - Mọi lứa tuổi</option>
                        <option value="C13">C13 - Từ 13 tuổi</option>
                        <option value="C16">C16 - Từ 16 tuổi</option>
                        <option value="C18">C18 - Từ 18 tuổi</option>
                    </select>
                </div>

                <div class="mb-3.5">
                    <label asp-for="DurationMinutes" class="@fieldLabel"></label>
                    <input asp-for="DurationMinutes" type="number" min="1" max="600" class="@fieldInput" />
                    <span asp-validation-for="DurationMinutes" class="@fieldError"></span>
                </div>

                <div class="mb-3.5">
                    <label asp-for="ReleaseDate" class="@fieldLabel"></label>
                    <input asp-for="ReleaseDate" type="date"
                           min="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" class="@fieldInput" />
                    <span asp-validation-for="ReleaseDate" class="@fieldError"></span>
                </div>

                <div class="mb-3.5">
                    <label asp-for="Language" class="@fieldLabel"></label>
                    <input asp-for="Language" class="@fieldInput" />
                </div>

                <div class="mb-3.5">
                    <label asp-for="Subtitle" class="@fieldLabel"></label>
                    <input asp-for="Subtitle" class="@fieldInput" />
                </div>

                <div class="mb-3.5">
                    <label asp-for="Director" class="@fieldLabel"></label>
                    <input asp-for="Director" class="@fieldInput" />
                </div>

                <div class="mb-3.5 col-span-2">
                    <label asp-for="CastMembers" class="@fieldLabel"></label>
                    <textarea asp-for="CastMembers" class="@fieldInput min-h-[90px] resize-y"></textarea>
                </div>

                <div class="mb-3.5 col-span-2">
                    <label asp-for="Description" class="@fieldLabel"></label>
                    <textarea asp-for="Description" class="@fieldInput min-h-[110px] resize-y"></textarea>
                </div>
            </div>
        </div>

        <div class="@card">
            <p class="@sectionTitle">Hình ảnh & Video</p>
            <div class="grid grid-cols-2 gap-x-5 gap-y-1">
                <div class="mb-3.5">
                    <label asp-for="PosterFile" class="@fieldLabel"></label>
                    @if (!string.IsNullOrEmpty(Model.PosterUrl))
                    {
                        <img src="@Model.PosterUrl" alt="Poster hiện tại" class="w-24 h-36 object-cover rounded-lg mb-2 border border-[#e0c0b2]" />
                    }
                    <input asp-for="PosterFile" type="file" accept="image/*" class="@fileInput" />
                    <span asp-validation-for="PosterFile" class="@fieldError"></span>
                    <p class="text-xs text-[#584237] mt-1">Để trống nếu muốn giữ ảnh hiện tại.</p>
                </div>
                <div class="mb-3.5">
                    <label asp-for="BannerFile" class="@fieldLabel"></label>
                    @if (!string.IsNullOrEmpty(Model.BannerUrl))
                    {
                        <img src="@Model.BannerUrl" alt="Banner hiện tại" class="w-full h-24 object-cover rounded-lg mb-2 border border-[#e0c0b2]" />
                    }
                    <input asp-for="BannerFile" type="file" accept="image/*" class="@fileInput" />
                    <span asp-validation-for="BannerFile" class="@fieldError"></span>
                    <p class="text-xs text-[#584237] mt-1">Để trống nếu muốn giữ ảnh hiện tại.</p>
                </div>
                <div class="mb-3.5 col-span-2">
                    <label asp-for="TrailerFile" class="@fieldLabel"></label>
                    @if (!string.IsNullOrEmpty(Model.TrailerUrl))
                    {
                        <video src="@Model.TrailerUrl" controls class="w-full max-h-64 rounded-lg mb-2 border border-[#e0c0b2] bg-black"></video>
                    }
                    <input asp-for="TrailerFile" type="file" accept="video/*" class="@fileInput" />
                    <span asp-validation-for="TrailerFile" class="@fieldError"></span>
                    <p class="text-xs text-[#584237] mt-1">Tối đa 100MB. Để trống nếu muốn giữ video hiện tại.</p>
                </div>
            </div>
        </div>

        <div class="@card">
            <p class="@sectionTitle">Thể loại</p>
            @if (Model.AvailableGenres.Any())
            {
                <div class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-2">
                    @foreach (var genre in Model.AvailableGenres)
                    {
                        <label class="flex items-center gap-1.5 px-2.5 py-2 border border-[#e0c0b2] rounded-lg cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/10">
                            <input type="checkbox" name="SelectedGenreIds" value="@genre.Id" class="accent-primary cursor-pointer"
                                   @(Model.SelectedGenreIds.Contains(genre.Id) ? "checked" : "") />
                            <span class="text-sm text-[#191c1d]">@genre.Name</span>
                        </label>
                    }
                </div>
            }
            else
            {
                <p class="text-[#584237] text-sm">Chưa có thể loại nào trong hệ thống.</p>
            }
        </div>

        <div class="@card">
            <p class="@sectionTitle">Slug URL</p>
            <div class="mb-3.5">
                <label asp-for="Slug" class="@fieldLabel"></label>
                <input asp-for="Slug" readonly class="@fieldInput bg-[#edeeef]" />
                <p class="text-xs text-[#584237] mt-1">Slug không thay đổi khi sửa để giữ nguyên URL.</p>
            </div>
        </div>

        <div class="flex gap-3 mt-6">
            <button type="submit" class="inline-flex items-center px-5 py-2.5 bg-primary hover:bg-primary-dark text-white rounded-lg text-sm font-semibold transition-colors">Lưu thay đổi</button>
            <a class="inline-flex items-center px-5 py-2.5 bg-[#edeeef] text-[#191c1d] rounded-lg text-sm font-semibold hover:bg-gray-200 transition-colors" href="@Url.Action("Index", "MovieManagement")">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
