@model MovieListViewModel
@{
    ViewData["Title"] = "Quản lý phim";
    ViewData["SidebarNewUrl"] = Url.Action("Create", "MovieManagement");
    ViewData["SidebarNewLabel"] = "Add New Movie";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="flex justify-between items-start mb-6 gap-4 flex-wrap">
    <div>
        <h1 class="font-head text-2xl font-extrabold text-[#191c1d] mb-0.5">Danh sách phim</h1>
        <p class="text-sm text-gray-500">Quản lý kho phim và trạng thái phát hành toàn hệ thống</p>
    </div>
    <a class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-primary hover:bg-primary-dark text-white rounded-lg text-xs font-bold tracking-wide whitespace-nowrap transition-colors"
       href="@Url.Action("Create", "MovieManagement")">
        <span class="material-symbols-outlined" style="font-size:18px">add_circle</span>
        THÊM PHIM MỚI
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="px-4 py-3 rounded-lg mb-4 text-sm bg-green-50 text-green-700 border border-green-200">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="px-4 py-3 rounded-lg mb-4 text-sm bg-red-50 text-red-700 border border-red-200">@TempData["Error"]</div>
}

<div class="bg-white rounded-xl p-5 mb-5 border border-[#e8eaed]">
    <form method="get" action="@Url.Action("Index", "MovieManagement")">
        <div class="flex gap-3.5 flex-wrap items-end">
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-gray-500 uppercase tracking-wide">Trạng thái</label>
                <select name="status"
                        class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white min-w-[155px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20">
                    @{
                        var statusFilter = Model.StatusFilter ?? "";
                        var statusOpts = new[] {
                            ("", "Tất cả trạng thái"),
                            ("Now Showing", "Đang chiếu"),
                            ("Coming Soon", "Sắp chiếu"),
                            ("Stopped", "Ngừng chiếu"),
                        };
                        foreach (var (val, text) in statusOpts)
                        {
                            if (val == statusFilter)
                            {
                                <option value="@val" selected>@text</option>
                            }
                            else
                            {
                                <option value="@val">@text</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-gray-500 uppercase tracking-wide">Thể loại</label>
                <select name="genre"
                        class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white min-w-[155px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20">
                    @{
                        var genreFilter = Model.GenreFilter ?? "";
                        if (genreFilter == "")
                        {
                            <option value="" selected>Tất cả thể loại</option>
                        }
                        else
                        {
                            <option value="">Tất cả thể loại</option>
                        }
                        foreach (var g in Model.AvailableGenres)
                        {
                            if (g.Name == genreFilter)
                            {
                                <option value="@g.Name" selected>@g.Name</option>
                            }
                            else
                            {
                                <option value="@g.Name">@g.Name</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-gray-500 uppercase tracking-wide">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" style="font-size:18px">search</span>
                    <input type="text" name="search" value="@Model.Search" placeholder="Tìm kiếm phim..."
                           class="pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm bg-white min-w-[220px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
                </div>
            </div>
            <div class="flex flex-col gap-1.5">
                <button type="submit"
                        class="inline-flex items-center gap-1.5 px-4 py-2 bg-secondary-dark hover:bg-[#002f6c] text-white rounded-lg text-sm font-semibold whitespace-nowrap transition-colors">
                    <span class="material-symbols-outlined" style="font-size:18px">filter_list</span>
                    Áp dụng bộ lọc
                </button>
            </div>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter) || !string.IsNullOrEmpty(Model.GenreFilter))
            {
                <a class="text-sm text-gray-500 hover:text-primary py-2 self-end" href="@Url.Action("Index", "MovieManagement")">✕ Xóa bộ lọc</a>
            }
        </div>
    </form>
</div>

<div class="bg-white rounded-xl border border-[#e8eaed] overflow-hidden mb-5">
    @if (Model.Movies.Any())
    {
        <table class="w-full border-collapse">
            <thead>
                <tr class="bg-gray-900">
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Poster</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Tên Phim</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Thể Loại</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Thời Lượng</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Trạng Thái</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var movie in Model.Movies)
                {
                    var badge = movie.Status switch
                    {
                        "Now Showing" => ("bg-green-100 text-green-700", "bg-green-600", "Đang chiếu"),
                        "Coming Soon" => ("bg-orange-50 text-orange-700", "bg-orange-500", "Sắp chiếu"),
                        "Stopped"     => ("bg-gray-100 text-gray-600", "bg-gray-400", "Ngừng chiếu"),
                        _             => ("bg-gray-100 text-gray-600", "bg-gray-400", movie.Status ?? "—")
                    };
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            @if (!string.IsNullOrEmpty(movie.PosterUrl))
                            {
                                <img class="w-[42px] h-[60px] object-cover rounded block" src="@movie.PosterUrl" alt="@movie.Title"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="w-[42px] h-[60px] bg-gray-100 rounded items-center justify-center text-[.6rem] text-gray-400 text-center" style="display:none">No img</div>
                            }
                            else
                            {
                                <div class="w-[42px] h-[60px] bg-gray-100 rounded flex items-center justify-center text-[.6rem] text-gray-400 text-center">No img</div>
                            }
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <div class="font-bold text-sm mb-0.5 max-w-[220px]">@movie.Title</div>
                            @if (movie.ReleaseDate.HasValue)
                            {
                                <div class="text-xs text-gray-500">Khởi chiếu: @movie.ReleaseDate.Value.ToString("dd/MM/yyyy")</div>
                            }
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <span class="text-gray-700">@(movie.GenreNames.Any() ? string.Join(", ", movie.GenreNames) : "—")</span>
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">@(movie.DurationMinutes.HasValue ? $"{movie.DurationMinutes} phút" : "—")</td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold whitespace-nowrap @badge.Item1">
                                <span class="w-[7px] h-[7px] rounded-full shrink-0 @badge.Item2"></span>
                                @badge.Item3
                            </span>
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <div class="flex items-center gap-1.5">
                                <a class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-sky-500 hover:bg-sky-100 transition-colors"
                                   href="@Url.Action("Edit", "MovieManagement", new { id = movie.Id })" title="Xem chi tiết">
                                    <span class="material-symbols-outlined" style="font-size:18px">visibility</span>
                                </a>
                                <a class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-amber-500 hover:bg-amber-100 transition-colors"
                                   href="@Url.Action("Edit", "MovieManagement", new { id = movie.Id })" title="Chỉnh sửa">
                                    <span class="material-symbols-outlined" style="font-size:18px">edit</span>
                                </a>
                                <form method="post"
                                      action="@Url.Action("ToggleStatus", "MovieManagement", new { id = movie.Id })"
                                      class="inline">
                                    @Html.AntiForgeryToken()
                                    @if (movie.Status == "Stopped")
                                    {
                                        <button type="submit" class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-green-500 hover:bg-green-100 transition-colors" title="Kích hoạt"
                                                onclick="return confirm('Kích hoạt phim này?')">
                                            <span class="material-symbols-outlined" style="font-size:18px">play_circle</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-red-500 hover:bg-red-100 transition-colors" title="Ngừng chiếu"
                                                onclick="return confirm('Ngừng chiếu phim này?')">
                                            <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                                        </button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="text-center py-16 px-8 text-gray-400 text-sm">
            <span class="material-symbols-outlined block mb-3" style="font-size:48px">movie_filter</span>
            Không tìm thấy phim nào.
        </div>
    }
</div>

@{
    int cp = Model.CurrentPage;
    int tp = Model.TotalPages;
    int fromItem = Model.TotalCount == 0 ? 0 : (cp - 1) * Model.PageSize + 1;
    int toItem   = Math.Min(cp * Model.PageSize, Model.TotalCount);

    var pages = new List<int?>();
    for (int i = 1; i <= tp; i++)
    {
        if (i == 1 || i == tp || (i >= cp - 2 && i <= cp + 2))
            pages.Add(i);
        else if (pages.Count == 0 || pages[pages.Count - 1] != null)
            pages.Add(null);
    }

    string PageUrl(int p) => Url.Action("Index", "MovieManagement",
        new { search = Model.Search, status = Model.StatusFilter, genre = Model.GenreFilter, page = p })!;

    const string pgBtn = "min-w-9 h-9 px-2 flex items-center justify-center border border-gray-200 rounded-md text-sm text-gray-700 bg-white hover:bg-[#fff7f0] hover:border-primary hover:text-primary transition-colors";
}
<div class="flex items-center justify-between flex-wrap gap-3">
    <span class="text-sm text-gray-500">
        Hiển thị <strong class="text-[#191c1d]">@fromItem–@toItem</strong> trên <strong class="text-[#191c1d]">@Model.TotalCount</strong> phim
    </span>
    @if (tp > 1)
    {
        <div class="flex gap-1.5 flex-wrap">
            <a class="@pgBtn @(cp == 1 ? "opacity-40 pointer-events-none" : "")" href="@PageUrl(cp - 1)">&lsaquo;</a>
            @foreach (var pg in pages)
            {
                if (pg == null)
                {
                    <span class="min-w-9 h-9 px-2 flex items-center justify-center text-gray-400">…</span>
                }
                else if (pg == cp)
                {
                    <a class="min-w-9 h-9 px-2 flex items-center justify-center border border-primary rounded-md text-sm bg-primary text-white font-bold" href="@PageUrl(pg.Value)">@pg</a>
                }
                else
                {
                    <a class="@pgBtn" href="@PageUrl(pg.Value)">@pg</a>
                }
            }
            <a class="@pgBtn @(cp == tp ? "opacity-40 pointer-events-none" : "")" href="@PageUrl(cp + 1)">&rsaquo;</a>
        </div>
    }
</div>
