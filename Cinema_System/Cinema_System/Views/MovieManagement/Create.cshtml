@model MovieFormViewModel
@{
    ViewData["Title"] = "Thêm Phim Mới";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

@section Styles {
<style>
    .mf-wrap { max-width: 860px; margin: 0 auto 2rem; padding: 0; }
    .mf-title { font-family: var(--font-head); font-size: 1.6rem; font-weight: 800; color: var(--on-surface); margin-bottom: 1.5rem; }
    .mf-card { background: var(--white); border-radius: var(--radius-xl); box-shadow: var(--shadow-sm); padding: 1.75rem; margin-bottom: 1.25rem; }
    .mf-section-title { font-weight: 700; font-size: 1rem; color: var(--on-surface); margin-bottom: 1rem; padding-bottom: .5rem; border-bottom: 2px solid var(--surface-container); }
    .mf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .9rem 1.25rem; }
    .mf-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: .9rem 1.25rem; }
    .mf-full { grid-column: 1 / -1; }
    .mf-field { margin-bottom: .9rem; }
    .mf-field label { display: block; font-weight: 600; color: var(--on-surface-variant); margin-bottom: .4rem; font-size: .88rem; }
    .mf-field input, .mf-field textarea, .mf-field select { width: 100%; padding: .6rem .8rem; border: 1px solid var(--outline-variant); border-radius: var(--radius); background: var(--white); font-family: var(--font-body); font-size: .9rem; box-sizing: border-box; }
    .mf-field textarea { min-height: 90px; resize: vertical; }
    .mf-field input:focus, .mf-field textarea:focus, .mf-field select:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(243,112,33,.15); }
    .mf-error { color: #b91c1c; font-size: .82rem; margin-top: .3rem; display: block; }
    .mf-summary { color: #b91c1c; font-size: .9rem; margin-bottom: 1rem; }
    .mf-genres-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: .5rem; }
    .mf-genre-item { display: flex; align-items: center; gap: .4rem; padding: .4rem .6rem; border: 1px solid var(--outline-variant); border-radius: var(--radius); cursor: pointer; }
    .mf-genre-item:has(input:checked) { border-color: var(--primary); background: rgba(243,112,33,.08); }
    .mf-genre-item input { accent-color: var(--primary); cursor: pointer; }
    .mf-genre-item span { font-size: .88rem; color: var(--on-surface); }
    .mf-actions { display: flex; gap: .75rem; margin-top: 1.5rem; }
    .mf-btn { padding: .6rem 1.3rem; border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; font-family: var(--font-body); text-decoration: none; display: inline-flex; align-items: center; font-size: .9rem; }
    .mf-btn-primary { background: var(--primary); color: var(--white); }
    .mf-btn-primary:hover { background: var(--primary-dark); }
    .mf-btn-ghost { background: var(--surface-container); color: var(--on-surface); }
    .mf-hint { font-size: .78rem; color: var(--on-surface-variant); margin-top: .25rem; }
</style>
}

<div class="mf-wrap">
    <h1 class="mf-title">Thêm Phim Mới</h1>

    <form method="post" action="@Url.Action("Create", "MovieManagement")">
        @Html.AntiForgeryToken()

        <div class="mf-card">
            <p class="mf-section-title">Thông tin cơ bản</p>
            <div asp-validation-summary="ModelOnly" class="mf-summary"></div>

            <div class="mf-grid">
                <div class="mf-field mf-full">
                    <label asp-for="Title"></label>
                    <input asp-for="Title" placeholder="Tên phim" />
                    <span asp-validation-for="Title" class="mf-error"></span>
                </div>

                <div class="mf-field">
                    <label asp-for="Status"></label>
                    <select asp-for="Status">
                        <option value="Coming Soon">Sắp chiếu</option>
                        <option value="Now Showing">Đang chiếu</option>
                        <option value="Inactive">Tạm ngừng</option>
                    </select>
                    <span asp-validation-for="Status" class="mf-error"></span>
                </div>

                <div class="mf-field">
                    <label asp-for="AgeRating"></label>
                    <select asp-for="AgeRating">
                        <option value="">-- Chọn --</option>
                        <option value="P">P - Mọi lứa tuổi</option>
                        <option value="C13">C13 - Từ 13 tuổi</option>
                        <option value="C16">C16 - Từ 16 tuổi</option>
                        <option value="C18">C18 - Từ 18 tuổi</option>
                    </select>
                </div>

                <div class="mf-field">
                    <label asp-for="DurationMinutes"></label>
                    <input asp-for="DurationMinutes" type="number" min="1" max="600" placeholder="VD: 120" />
                    <span asp-validation-for="DurationMinutes" class="mf-error"></span>
                </div>

                <div class="mf-field">
                    <label asp-for="ReleaseDate"></label>
                    <input asp-for="ReleaseDate" type="date"
                           min="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="ReleaseDate" class="mf-error"></span>
                </div>

                <div class="mf-field">
                    <label asp-for="Language"></label>
                    <input asp-for="Language" placeholder="VD: Tiếng Anh" />
                </div>

                <div class="mf-field">
                    <label asp-for="Subtitle"></label>
                    <input asp-for="Subtitle" placeholder="VD: Tiếng Việt" />
                </div>

                <div class="mf-field">
                    <label asp-for="Director"></label>
                    <input asp-for="Director" placeholder="Tên đạo diễn" />
                </div>

                <div class="mf-field mf-full">
                    <label asp-for="CastMembers"></label>
                    <textarea asp-for="CastMembers" placeholder="Danh sách diễn viên, phân cách bằng dấu phẩy"></textarea>
                </div>

                <div class="mf-field mf-full">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" style="min-height:110px" placeholder="Mô tả nội dung phim"></textarea>
                </div>
            </div>
        </div>

        <div class="mf-card">
            <p class="mf-section-title">URL Media</p>
            <div class="mf-grid">
                <div class="mf-field">
                    <label asp-for="PosterUrl"></label>
                    <input asp-for="PosterUrl" placeholder="https://..." />
                </div>
                <div class="mf-field">
                    <label asp-for="BannerUrl"></label>
                    <input asp-for="BannerUrl" placeholder="https://..." />
                </div>
                <div class="mf-field mf-full">
                    <label asp-for="TrailerUrl"></label>
                    <input asp-for="TrailerUrl" placeholder="https://youtube.com/..." />
                </div>
            </div>
        </div>

        <div class="mf-card">
            <p class="mf-section-title">Thể loại</p>
            @if (Model.AvailableGenres.Any())
            {
                <div class="mf-genres-grid">
                    @foreach (var genre in Model.AvailableGenres)
                    {
                        <label class="mf-genre-item">
                            <input type="checkbox" name="SelectedGenreIds" value="@genre.Id"
                                   @(Model.SelectedGenreIds.Contains(genre.Id) ? "checked" : "") />
                            <span>@genre.Name</span>
                        </label>
                    }
                </div>
            }
            else
            {
                <p style="color:var(--on-surface-variant);font-size:.9rem">Chưa có thể loại nào trong hệ thống.</p>
            }
        </div>

        <div class="mf-card">
            <p class="mf-section-title">Slug URL (tùy chọn)</p>
            <div class="mf-field">
                <label asp-for="Slug"></label>
                <input asp-for="Slug" placeholder="ten-phim-theo-url (để trống sẽ tự tạo)" />
                <p class="mf-hint">Nếu để trống, slug sẽ được tự động tạo từ tên phim.</p>
            </div>
        </div>

        <div class="mf-actions">
            <button type="submit" class="mf-btn mf-btn-primary">Thêm phim</button>
            <a class="mf-btn mf-btn-ghost" href="@Url.Action("Index", "MovieManagement")">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
