@model FoodBeverageListViewModel
@{
    ViewData["Title"] = "Quản Lý Menu";
    ViewData["SidebarNewUrl"] = Url.Action("Create", "FoodBeverages");
    ViewData["SidebarNewLabel"] = "Thêm Món Mới";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="flex justify-between items-start mb-6 gap-4 flex-wrap">
    <div>
        <h1 class="font-head text-2xl font-extrabold text-[#191c1d] mb-0.5">Danh sách món ăn & thức uống</h1>
        <p class="text-sm text-gray-500">Quản lý menu và tình trạng hàng hóa toàn hệ thống</p>
    </div>
    <a class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-primary hover:bg-primary-dark text-white rounded-lg text-xs font-bold tracking-wide whitespace-nowrap transition-colors"
       href="@Url.Action("Create", "FoodBeverages")">
        <span class="material-symbols-outlined" style="font-size:18px">add_circle</span>
        THÊM MÓN MỚI
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="px-4 py-3 rounded-lg mb-4 text-sm bg-green-50 text-green-700 border border-green-200">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="px-4 py-3 rounded-lg mb-4 text-sm bg-red-50 text-red-700 border border-red-200">@TempData["Error"]</div>
}

<div class="bg-white rounded-xl p-5 mb-5 border border-[#e8eaed]">
    <form method="get" action="@Url.Action("Index", "FoodBeverages")">
        <div class="flex gap-3.5 flex-wrap items-end">
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-gray-500 uppercase tracking-wide">Tình trạng</label>
                <select name="status"
                        class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white min-w-[155px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20">
                    @{
                        var sf = Model.StatusFilter ?? "";
                        var statusOpts = new[] {
                            ("", "Tất cả tình trạng"),
                            ("In Stock", "Còn hàng"),
                            ("Out of Stock", "Hết hàng"),
                            ("Discontinued", "Ngừng bán"),
                        };
                        foreach (var (val, text) in statusOpts)
                        {
                            if (val == sf)
                            {
                                <option value="@val" selected>@text</option>
                            }
                            else
                            {
                                <option value="@val">@text</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-gray-500 uppercase tracking-wide">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" style="font-size:18px">search</span>
                    <input type="text" name="search" value="@Model.Search" placeholder="Tìm kiếm món..."
                           class="pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm bg-white min-w-[220px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
                </div>
            </div>
            <div class="flex flex-col gap-1.5">
                <button type="submit"
                        class="inline-flex items-center gap-1.5 px-4 py-2 bg-secondary-dark hover:bg-[#002f6c] text-white rounded-lg text-sm font-semibold whitespace-nowrap transition-colors">
                    <span class="material-symbols-outlined" style="font-size:18px">filter_list</span>
                    Áp dụng bộ lọc
                </button>
            </div>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter))
            {
                <a class="text-sm text-gray-500 hover:text-primary py-2 self-end" href="@Url.Action("Index", "FoodBeverages")">✕ Xóa bộ lọc</a>
            }
        </div>
    </form>
</div>

<div class="bg-white rounded-xl border border-[#e8eaed] overflow-hidden mb-5">
    @if (Model.Items.Any())
    {
        <table class="w-full border-collapse">
            <thead>
                <tr class="bg-gray-900">
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Hình</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Tên Món</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Giá</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Tình Trạng</th>
                    <th class="px-4 py-3.5 text-left text-gray-300 text-xs font-bold tracking-wide uppercase whitespace-nowrap">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var badge = item.StockStatus switch
                    {
                        "In Stock"     => ("bg-green-100 text-green-700", "bg-green-600", "Còn hàng"),
                        "Out of Stock" => ("bg-yellow-100 text-yellow-800", "bg-amber-600", "Hết hàng"),
                        "Discontinued" => ("bg-gray-100 text-gray-600", "bg-gray-400", "Ngừng bán"),
                        _              => ("bg-gray-100 text-gray-600", "bg-gray-400", item.StockStatus ?? "—")
                    };
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img class="w-13 h-13 object-cover rounded-lg block" style="width:52px;height:52px" src="@item.ImageUrl" alt="@item.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="bg-gray-100 rounded-lg items-center justify-center text-[.6rem] text-gray-400" style="width:52px;height:52px;display:none">No img</div>
                            }
                            else
                            {
                                <div class="bg-gray-100 rounded-lg flex items-center justify-center text-[.6rem] text-gray-400" style="width:52px;height:52px">No img</div>
                            }
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <div class="font-bold text-sm mb-0.5">@item.Name</div>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <div class="text-xs text-gray-500 max-w-[220px] truncate" title="@item.Description">@item.Description</div>
                            }
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <span class="font-bold text-primary whitespace-nowrap">@item.Price.ToString("N0") ₫</span>
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold whitespace-nowrap @badge.Item1">
                                <span class="w-[7px] h-[7px] rounded-full shrink-0 @badge.Item2"></span>
                                @badge.Item3
                            </span>
                        </td>
                        <td class="px-4 py-3.5 border-b border-gray-100 text-sm align-middle">
                            <div class="flex items-center gap-1.5">
                                <a class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-amber-500 hover:bg-amber-100 transition-colors"
                                   href="@Url.Action("Edit", "FoodBeverages", new { id = item.Id })" title="Chỉnh sửa">
                                    <span class="material-symbols-outlined" style="font-size:18px">edit</span>
                                </a>

                                <form method="post"
                                      action="@Url.Action("ToggleVisibility", "FoodBeverages", new { id = item.Id })"
                                      class="inline">
                                    @Html.AntiForgeryToken()
                                    @if (item.StockStatus == "Discontinued")
                                    {
                                        <button type="submit" class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-green-500 hover:bg-green-100 transition-colors" title="Hiện món"
                                                onclick="return confirm('Hiện lại món này?')">
                                            <span class="material-symbols-outlined" style="font-size:18px">visibility</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-gray-500 hover:bg-gray-200 transition-colors" title="Ẩn món"
                                                onclick="return confirm('Ẩn món này khỏi menu?')">
                                            <span class="material-symbols-outlined" style="font-size:18px">visibility_off</span>
                                        </button>
                                    }
                                </form>

                                @if (!item.HasOrders)
                                {
                                    <form method="post"
                                          action="@Url.Action("Delete", "FoodBeverages", new { id = item.Id })"
                                          class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-red-500 hover:bg-red-100 transition-colors" title="Xóa vĩnh viễn"
                                                onclick="return confirm('Xóa vĩnh viễn món này?')">
                                            <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="w-8 h-8 rounded-md flex items-center justify-center bg-gray-100 text-gray-300 cursor-not-allowed" title="Đã có trong lịch sử đặt hàng" disabled>
                                        <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="text-center py-16 px-8 text-gray-400 text-sm">
            <span class="material-symbols-outlined block mb-3" style="font-size:48px">restaurant</span>
            Không tìm thấy món nào.
        </div>
    }
</div>

@{
    int cp = Model.CurrentPage;
    int tp = Model.TotalPages;
    int fromItem = Model.TotalCount == 0 ? 0 : (cp - 1) * Model.PageSize + 1;
    int toItem   = Math.Min(cp * Model.PageSize, Model.TotalCount);

    var pages = new List<int?>();
    for (int i = 1; i <= tp; i++)
    {
        if (i == 1 || i == tp || (i >= cp - 2 && i <= cp + 2))
            pages.Add(i);
        else if (pages.Count == 0 || pages[pages.Count - 1] != null)
            pages.Add(null);
    }

    string PageUrl(int p) => Url.Action("Index", "FoodBeverages",
        new { search = Model.Search, status = Model.StatusFilter, page = p })!;

    const string pgBtn = "min-w-9 h-9 px-2 flex items-center justify-center border border-gray-200 rounded-md text-sm text-gray-700 bg-white hover:bg-[#fff7f0] hover:border-primary hover:text-primary transition-colors";
}
<div class="flex items-center justify-between flex-wrap gap-3">
    <span class="text-sm text-gray-500">
        Hiển thị <strong class="text-[#191c1d]">@fromItem–@toItem</strong> trên <strong class="text-[#191c1d]">@Model.TotalCount</strong> món
    </span>
    @if (tp > 1)
    {
        <div class="flex gap-1.5 flex-wrap">
            <a class="@pgBtn @(cp == 1 ? "opacity-40 pointer-events-none" : "")" href="@PageUrl(cp - 1)">&lsaquo;</a>
            @foreach (var pg in pages)
            {
                if (pg == null)
                {
                    <span class="min-w-9 h-9 px-2 flex items-center justify-center text-gray-400">…</span>
                }
                else if (pg == cp)
                {
                    <a class="min-w-9 h-9 px-2 flex items-center justify-center border border-primary rounded-md text-sm bg-primary text-white font-bold" href="@PageUrl(pg.Value)">@pg</a>
                }
                else
                {
                    <a class="@pgBtn" href="@PageUrl(pg.Value)">@pg</a>
                }
            }
            <a class="@pgBtn @(cp == tp ? "opacity-40 pointer-events-none" : "")" href="@PageUrl(cp + 1)">&rsaquo;</a>
        </div>
    }
</div>
