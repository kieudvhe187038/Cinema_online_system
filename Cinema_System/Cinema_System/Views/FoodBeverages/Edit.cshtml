@model FoodBeverageFormViewModel
@{
    ViewData["Title"] = "Sửa Món";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

@{
    const string fieldInput = "w-full px-3 py-2.5 border border-gray-300 rounded-lg bg-white text-sm box-border focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20";
    const string fieldLabel = "block font-semibold text-gray-700 mb-1.5 text-sm";
    const string fieldError = "block text-red-700 text-xs mt-1";
    const string fileInput = "w-full text-sm text-[#584237] border border-gray-300 rounded-lg p-2 cursor-pointer file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary file:text-white file:text-sm file:font-semibold hover:file:bg-primary-dark file:cursor-pointer";
}

<div class="max-w-[620px] mx-auto mb-8">
    <div class="mb-6">
        <h1 class="font-head text-2xl font-extrabold text-[#191c1d] mb-0.5">Sửa Món: @Model.Name</h1>
        <p class="text-sm text-gray-500">Cập nhật thông tin món ăn hoặc thức uống</p>
    </div>

    <div class="bg-white rounded-xl border border-[#e8eaed] p-7">
        <p class="font-bold text-base text-[#191c1d] mb-4 pb-2 border-b-2 border-gray-100">Thông tin món</p>
        <form method="post" action="@Url.Action("Edit", "FoodBeverages", new { id = Model.Id })" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            @* Giữ lại ảnh hiện tại nếu không upload ảnh mới *@
            <input type="hidden" asp-for="ImageUrl" />
            <div asp-validation-summary="ModelOnly" class="text-red-700 text-sm mb-4"></div>

            <div class="mb-4">
                <label asp-for="Name" class="@fieldLabel">Tên món</label>
                <input asp-for="Name" class="@fieldInput" />
                <span asp-validation-for="Name" class="@fieldError"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Price" class="@fieldLabel">Giá (₫)</label>
                <input asp-for="Price" type="number" min="0" step="1000" class="@fieldInput" />
                <span asp-validation-for="Price" class="@fieldError"></span>
            </div>

            <div class="mb-4">
                <label asp-for="StockStatus" class="@fieldLabel">Tình trạng</label>
                <select asp-for="StockStatus" class="@fieldInput">
                    <option value="In Stock">Còn hàng</option>
                    <option value="Out of Stock">Hết hàng</option>
                    <option value="Discontinued">Ngừng bán</option>
                </select>
                <span asp-validation-for="StockStatus" class="@fieldError"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="@fieldLabel">Mô tả</label>
                <textarea asp-for="Description" class="@fieldInput min-h-[90px] resize-y"></textarea>
            </div>

            <div class="mb-4">
                <label asp-for="ImageFile" class="@fieldLabel">Hình ảnh</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img id="imgCurrent" class="mb-2 w-24 h-24 object-cover rounded-lg border border-gray-200" src="@Model.ImageUrl" alt="Ảnh hiện tại"
                         onerror="this.style.display='none'" />
                }
                <input asp-for="ImageFile" type="file" accept="image/*" class="@fileInput" id="imgFileInput" />
                <span asp-validation-for="ImageFile" class="@fieldError"></span>
                <p class="text-xs text-gray-500 mt-1">Tối đa 10MB. Để trống nếu muốn giữ ảnh hiện tại.</p>
                <img id="imgPreview" class="mt-3 w-24 h-24 object-cover rounded-lg border border-gray-200 hidden" alt="preview" />
            </div>

            <div class="flex gap-3 mt-2">
                <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-primary hover:bg-primary-dark text-white rounded-lg text-sm font-semibold transition-colors">
                    <span class="material-symbols-outlined" style="font-size:18px">save</span>
                    Lưu thay đổi
                </button>
                <a class="inline-flex items-center px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-[#191c1d] rounded-lg text-sm font-semibold transition-colors" href="@Url.Action("Index", "FoodBeverages")">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const imgInput = document.getElementById('imgFileInput');
        const imgPreview = document.getElementById('imgPreview');
        imgInput?.addEventListener('change', () => {
            const file = imgInput.files?.[0];
            if (file) {
                imgPreview.src = URL.createObjectURL(file);
                imgPreview.classList.remove('hidden');
            } else {
                imgPreview.classList.add('hidden');
            }
        });
    </script>
}
