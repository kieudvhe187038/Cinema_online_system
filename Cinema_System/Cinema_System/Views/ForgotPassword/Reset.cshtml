@model Cinema_System.Application.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "_AuthLayout";
    var summaryErrors = ViewData.ModelState[string.Empty]?.Errors;
}

<div class="text-center mb-7">
    <div class="font-display-lg text-[36px] leading-none font-extrabold tracking-tight text-primary-container mb-2">CineStar</div>
    <h1 class="font-headline-md text-[22px] font-bold text-on-surface mb-1">Đặt Mật Khẩu Mới</h1>
    <p class="font-body-md text-[15px] text-on-surface-variant">
        Cho tài khoản <span class="font-bold text-on-surface">@Model.Email</span>
    </p>
</div>

<form asp-action="Reset" method="post" class="space-y-4">
    @if (summaryErrors != null && summaryErrors.Count > 0)
    {
        <div class="bg-error-container text-on-error-container rounded-lg px-md py-sm flex items-center gap-xs text-label-md">
            <span class="material-symbols-outlined text-[20px]">error</span>
            <span>@summaryErrors[0].ErrorMessage</span>
        </div>
    }

    <div class="space-y-2">
        <label asp-for="NewPassword" class="font-label-md text-label-md text-on-surface-variant block"></label>
        <div class="relative">
            <span class="material-symbols-outlined text-[20px] absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
            <input asp-for="NewPassword" autocomplete="new-password" placeholder="6–72 ký tự (chữ, số, ký tự đặc biệt)"
                   minlength="6" maxlength="72" pattern="[!-~]{6,72}"
                   title="Mật khẩu 6–72 ký tự, gồm chữ/số/ký tự đặc biệt, không dấu tiếng Việt hay khoảng trắng."
                   class="w-full pl-11 pr-11 py-3 bg-surface-container rounded-lg border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" />
            <button type="button" class="toggle-pw absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary">
                <span class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
        </div>
        <span asp-validation-for="NewPassword" class="text-error text-label-sm block"></span>
    </div>

    <div class="space-y-2">
        <label asp-for="ConfirmPassword" class="font-label-md text-label-md text-on-surface-variant block"></label>
        <div class="relative">
            <span class="material-symbols-outlined text-[20px] absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">lock_reset</span>
            <input asp-for="ConfirmPassword" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới"
                   minlength="6" maxlength="72"
                   class="w-full pl-11 pr-11 py-3 bg-surface-container rounded-lg border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" />
            <button type="button" class="toggle-pw absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary">
                <span class="material-symbols-outlined text-[20px]">visibility</span>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-error text-label-sm block"></span>
    </div>

    <button class="w-full bg-primary-container text-on-primary py-3 rounded-lg font-headline-md text-[16px] font-bold hover:scale-[1.01] active:scale-[0.99] transition-all duration-200 shadow-lg shadow-primary-container/30 mt-1" type="submit">
        Đặt Lại Mật Khẩu
    </button>
</form>

<div class="mt-6 text-center">
    <a class="font-label-sm text-label-sm text-on-surface-variant hover:underline inline-block" asp-controller="Login" asp-action="Login">← Quay lại đăng nhập</a>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.toggle-pw').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = btn.parentElement.querySelector('input');
                const icon = btn.querySelector('.material-symbols-outlined');
                if (input.type === 'password') { input.type = 'text'; icon.textContent = 'visibility_off'; }
                else { input.type = 'password'; icon.textContent = 'visibility'; }
            });
        });
    </script>
}
