@model Cinema_System.Application.ViewModels.VerifyOtpViewModel
@{
    ViewData["Title"] = "Xác nhận OTP";
    Layout = "_AuthLayout";
    var summaryErrors = ViewData.ModelState[string.Empty]?.Errors;
}

<div class="text-center mb-7">
    <div class="font-display-lg text-[36px] leading-none font-extrabold tracking-tight text-primary-container mb-2">CineStar</div>
    <h1 class="font-headline-md text-[22px] font-bold text-on-surface mb-1">Xác Nhận OTP</h1>
    <p class="font-body-md text-[15px] text-on-surface-variant">
        Nhập mã OTP đã gửi tới<br />
        <span class="font-bold text-on-surface">@Model.Email</span>
    </p>
</div>

@if (TempData["Message"] is string msg && !string.IsNullOrEmpty(msg))
{
    <div class="bg-secondary/10 text-secondary rounded-lg px-md py-sm flex items-center gap-xs text-label-md mb-4">
        <span class="material-symbols-outlined text-[20px]">info</span>
        <span>@msg</span>
    </div>
}

<form asp-action="VerifyOtp" method="post" class="space-y-5">
    @if (summaryErrors != null && summaryErrors.Count > 0)
    {
        <div class="bg-error-container text-on-error-container rounded-lg px-md py-sm flex items-center gap-xs text-label-md">
            <span class="material-symbols-outlined text-[20px]">error</span>
            <span>@summaryErrors[0].ErrorMessage</span>
        </div>
    }

    <div class="space-y-2">
        <label asp-for="Otp" class="font-label-md text-label-md text-on-surface-variant block">Mã OTP</label>
        <input asp-for="Otp" inputmode="numeric" maxlength="6" autocomplete="one-time-code" placeholder="••••••"
               class="w-full text-center text-[28px] tracking-[12px] font-bold py-3 bg-surface-container rounded-lg border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" />
        <span asp-validation-for="Otp" class="text-error text-label-sm block text-center"></span>
        <p class="text-center text-label-sm text-on-surface-variant">
            <span id="otpCountdown" data-seconds="@Model.OtpExpiresInSeconds"></span>
        </p>
    </div>

    <button class="w-full bg-primary-container text-on-primary py-3 rounded-lg font-headline-md text-[16px] font-bold hover:scale-[1.01] active:scale-[0.99] transition-all duration-200 shadow-lg shadow-primary-container/30" type="submit">
        Xác Nhận
    </button>
</form>

<div class="mt-5 text-center">
    <p class="font-body-md text-[15px] text-on-surface-variant">
        Không nhận được mã?
        <button type="submit" form="resendForm" class="text-primary font-bold hover:underline ml-1">Gửi lại OTP</button>
    </p>
    <form id="resendForm" asp-action="ResendOtp" method="post" class="hidden"></form>
    <a class="font-label-sm text-label-sm text-on-surface-variant hover:underline mt-2 inline-block" asp-controller="Login" asp-action="Login">← Quay lại đăng nhập</a>
</div>

@section Scripts {
    <script>
        const otp = document.querySelector('[name="Otp"]');
        if (otp) {
            otp.addEventListener('input', () => { otp.value = otp.value.replace(/\D/g, ''); });
        }

        // Đếm ngược thời gian sống của OTP
        (function () {
            const el = document.getElementById('otpCountdown');
            if (!el) return;
            let s = parseInt(el.dataset.seconds, 10) || 0;
            function fmt(x) { return Math.floor(x / 60) + ':' + String(x % 60).padStart(2, '0'); }
            function render() {
                if (s > 0) { el.textContent = 'Mã hết hạn sau ' + fmt(s); }
                else { el.textContent = 'Mã OTP đã hết hạn, vui lòng gửi lại.'; el.classList.add('text-error'); }
            }
            render();
            const t = setInterval(() => { if (s > 0) { s--; render(); } else { clearInterval(t); } }, 1000);
        })();
    </script>
}
