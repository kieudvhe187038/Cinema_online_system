@model Cinema_System.Application.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
    var summaryErrors = ViewData.ModelState[string.Empty]?.Errors;
}

<div class="text-center mb-7">
    <div class="font-display-lg text-[36px] leading-none font-extrabold tracking-tight text-primary-container mb-2">CineStar</div>
    <h1 class="font-headline-md text-[22px] font-bold text-on-surface mb-1">Quên Mật Khẩu</h1>
    <p class="font-body-md text-[15px] text-on-surface-variant">Nhập email để nhận mã OTP đặt lại mật khẩu</p>
</div>

<form asp-action="ForgotPassword" method="post" class="space-y-5">
    @if (summaryErrors != null && summaryErrors.Count > 0)
    {
        <div class="bg-error-container text-on-error-container rounded-lg px-md py-sm flex items-center gap-xs text-label-md">
            <span class="material-symbols-outlined text-[20px]">error</span>
            <span>@summaryErrors[0].ErrorMessage</span>
        </div>
    }

    <div class="space-y-2">
        <label asp-for="Email" class="font-label-md text-label-md text-on-surface-variant block">Email</label>
        <div class="relative">
            <span class="material-symbols-outlined text-[20px] absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">mail</span>
            <input asp-for="Email" autocomplete="email" placeholder="example@gmail.com"
                   class="w-full pl-11 pr-4 py-3 bg-surface-container rounded-lg border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" />
        </div>
        <span asp-validation-for="Email" class="text-error text-label-sm block"></span>
    </div>

    <button class="w-full bg-primary-container text-on-primary py-3 rounded-lg font-headline-md text-[16px] font-bold hover:scale-[1.01] active:scale-[0.99] transition-all duration-200 shadow-lg shadow-primary-container/30" type="submit">
        Gửi Mã Xác Nhận
    </button>
</form>

<div class="mt-6 text-center">
    <a class="font-label-sm text-label-sm text-on-surface-variant hover:underline inline-block" asp-controller="Login" asp-action="Login">← Quay lại đăng nhập</a>
</div>
