@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Carousel -->
<section class="hero-section">
    <div class="hero-bg">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0FbgZ6y1CTXLUavz6OcQqyy3wOQw7LKToKPZqdpUipNJzh1if505lNBz-Nl0Pzs0N0GHfEnGaUTMY312PfMQoLZRlabx70TlxkrcGT3IAHsRL99ttW-14Sbj1alQl_nJmSFiyvpfPHhv5SSPdp3XQIPP9Ud5X_akRP4ZzBZkkb7kr022Wqbhzx8GJpqH7LTSmzDwzqGWT1qReh0O1_zdtEeGNjkaANPVdHAAUxX_XWSyN_5PNmVeG3eN0GRjbEFTJEqDwoa2ZKAGd"
             alt="Hero Banner" />
        <div class="hero-gradient"></div>
    </div>
    <div class="hero-content">
        <span class="badge-hot" style="width:fit-content;display:inline-block">PHIM HOT</span>
        <h1>CHIẾN BINH CUỐI CÙNG: ĐẠI CHIẾN NGÂN HÀ</h1>
        <p>Hành trình bảo vệ vũ trụ của các chiến binh quả cảm. Một siêu phẩm kỹ xảo không thể bỏ lỡ tại CineStar trong tháng này.</p>
        <div class="hero-actions">
            <button class="btn-primary hero-btn">
                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">play_circle</span>
                ĐẶT VÉ NGAY
            </button>
            <button class="btn-ghost hero-btn">XEM TRAILER</button>
        </div>
    </div>
    <!-- Carousel Dots -->
    <div class="carousel-dots">
        <div class="dot active"></div>
        <div class="dot"></div>
        <div class="dot"></div>
    </div>
</section>

<!-- Quick Booking Bar -->
<section class="quick-book-section">
    <div class="quick-book-card">
        <div class="book-field">
            <label>
                <span class="material-symbols-outlined">movie</span> CHỌN PHIM
            </label>
            <select>
                <option>Tất cả các phim</option>
                <option>Chiến Binh Cuối Cùng</option>
                <option>Minions: Sự Trỗi Dậy</option>
            </select>
        </div>
        <div class="book-field">
            <label>
                <span class="material-symbols-outlined">calendar_today</span> CHỌN NGÀY
            </label>
            <select>
                <option>Hôm nay, 24/05</option>
                <option>Thứ 7, 25/05</option>
                <option>Chủ nhật, 26/05</option>
            </select>
        </div>
        <div class="book-field">
            <label>
                <span class="material-symbols-outlined">schedule</span> SUẤT CHIẾU
            </label>
            <select>
                <option>Chọn suất chiếu</option>
                <option>18:30 - 2D</option>
                <option>20:45 - 3D</option>
            </select>
        </div>
        <button class="btn-primary book-submit">
            <span class="material-symbols-outlined">confirmation_number</span> ĐẶT VÉ NHANH
        </button>
    </div>
</section>

