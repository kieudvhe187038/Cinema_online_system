@model Cinema_System.Application.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    primary: '#F37021',
                    'primary-dark': '#d85f15',
                    secondary: '#00488D',
                    tertiary: '#002F59',
                    light: '#F8F9FA',
                },
                fontFamily: {
                    heading: ['"Plus Jakarta Sans"', 'sans-serif'],
                    body: ['"Be Vietnam Pro"', 'sans-serif'],
                }
            }
        }
    }
</script>

<div class="min-h-screen bg-light font-body py-10 px-4">
    <div class="max-w-md mx-auto rounded-2xl bg-white p-8 shadow-md">
        <h1 class="mb-6 text-xl font-bold font-heading text-tertiary">🔒 Đổi mật khẩu</h1>

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="mb-3 text-sm text-red-600"></div>

            <div class="mb-4">
                <label asp-for="OldPassword" class="mb-1 block text-sm font-medium text-gray-700"></label>
                <input asp-for="OldPassword"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                <span asp-validation-for="OldPassword" class="text-sm text-red-600"></span>
            </div>

            <div class="mb-4">
                <label asp-for="NewPassword" class="mb-1 block text-sm font-medium text-gray-700"></label>
                <input asp-for="NewPassword"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                <span asp-validation-for="NewPassword" class="text-sm text-red-600"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="mb-1 block text-sm font-medium text-gray-700"></label>
                <input asp-for="ConfirmPassword"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600"></span>
            </div>

            <div class="mt-6 flex gap-3">
                <button type="submit"
                        class="flex-1 rounded-xl bg-primary px-4 py-3 font-semibold text-white hover:bg-primary-dark transition">
                    Xác nhận đổi
                </button>
                <a asp-action="Index"
                   class="flex-1 rounded-xl border-2 border-secondary px-4 py-3 text-center font-semibold text-secondary hover:bg-secondary hover:text-white transition">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
