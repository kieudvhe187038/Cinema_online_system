@model Cinema_System.Application.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    primary: '#F37021',
                    'primary-dark': '#d85f15',
                    secondary: '#00488D',
                    tertiary: '#002F59',
                    light: '#F8F9FA',
                },
                fontFamily: {
                    heading: ['"Plus Jakarta Sans"', 'sans-serif'],
                    body: ['"Be Vietnam Pro"', 'sans-serif'],
                }
            }
        }
    }
</script>

<div class="min-h-screen bg-light font-body py-10 px-4">
    <div class="max-w-2xl mx-auto">

        @if (TempData["Success"] != null)
        {
            <div class="mb-4 rounded-xl bg-green-100 border border-green-300 text-green-800 px-4 py-3">
                @TempData["Success"]
            </div>
        }

        <div class="rounded-2xl bg-gradient-to-r from-secondary to-tertiary p-8 text-center text-white shadow-lg font-heading">
            <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://placehold.co/130x130?text=Avatar" : Model.AvatarUrl)"
                 alt="Ảnh đại diện"
                 class="mx-auto h-32 w-32 rounded-full border-4 border-white object-cover bg-white shadow-md" />
            <h1 class="mt-4 text-2xl font-bold">@Model.FullName</h1>
            <span class="mt-1 inline-block rounded-full bg-white/20 px-3 py-1 text-sm">@Model.RoleName</span>

            @if (Model.RoleName == "CUSTOMER")
            {
                <div class="mt-3">
                <span class="inline-block rounded-full bg-primary px-4 py-1 font-semibold text-white">
                    ⭐ @Model.RewardPoints điểm
                </span>
            </div>
            }
        </div>


        <div class="mt-6 rounded-2xl bg-white p-6 shadow-md">
            <h2 class="mb-4 text-lg font-bold font-heading text-tertiary">Thông tin cá nhân</h2>

            <dl class="divide-y divide-gray-100">
                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Họ và tên</dt>
                    <dd class="font-semibold text-gray-800">@Model.FullName</dd>
                </div>
                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Email</dt>
                    <dd class="font-semibold text-gray-800">@Model.Email</dd>
                </div>
                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Số điện thoại</dt>
                    <dd class="font-semibold text-gray-800">
                        @(string.IsNullOrEmpty(Model.Phone) ? "Chưa cập nhật" : Model.Phone)
                    </dd>
                </div>

                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Ngày sinh</dt>
                    <dd class="font-semibold text-gray-800">
                        @if (Model.DateOfBirth == null)
                        {
                            <span>Chưa cập nhật</span>
                        }
                        else
                        {
                            @Model.DateOfBirth.Value.ToString("dd/MM/yyyy")
                            <span class="ml-2 rounded-full bg-secondary/10 px-2 py-0.5 text-sm text-secondary">
                                @Model.Age tuổi
                            </span>
                        }
                    </dd>
                </div>

                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Vai trò</dt>
                    <dd class="font-semibold text-gray-800">@Model.RoleName</dd>
                </div>
                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Trạng thái</dt>
                    <dd>
                        <span class="rounded-full px-3 py-1 text-sm font-semibold text-white
                            @(Model.Status == "Active" ? "bg-green-500" : "bg-red-500")">
                            @Model.Status
                        </span>
                    </dd>
                </div>
                <div class="flex justify-between py-3">
                    <dt class="font-medium text-gray-500">Ngày tạo tài khoản</dt>
                    <dd class="font-semibold text-gray-800">@Model.CreatedAt.ToString("dd/MM/yyyy")</dd>
                </div>
            </dl>
        </div>

        <div class="mt-6 flex gap-3">
            <a asp-action="Edit"
               class="flex-1 rounded-xl bg-primary px-4 py-3 text-center font-semibold text-white hover:bg-primary-dark transition">
                ✏️ Chỉnh sửa hồ sơ
            </a>
            <a asp-action="ChangePassword"
               class="flex-1 rounded-xl border-2 border-secondary bg-white px-4 py-3 text-center font-semibold text-secondary hover:bg-secondary hover:text-white transition">
                🔒 Đổi mật khẩu
            </a>
        </div>
    </div>
</div>
