@model Cinema_System.Application.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
    var summaryErrors = ViewData.ModelState[string.Empty]?.Errors;
}
<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Đăng Nhập | CineStar - Trải Nghiệm Điện Ảnh Đỉnh Cao</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#f37021",
                        "surface-container-low": "#f3f4f5",
                        "outline-variant": "#e0c0b2",
                        "secondary": "#265fa2",
                        "on-background": "#191c1d",
                        "surface": "#f8f9fa",
                        "error-container": "#ffdad6",
                        "on-error": "#ffffff",
                        "surface-variant": "#e1e3e4",
                        "on-primary-container": "#541f00",
                        "error": "#ba1a1a",
                        "on-surface-variant": "#584237",
                        "on-primary": "#ffffff",
                        "primary": "#a04100",
                        "surface-container-lowest": "#ffffff",
                        "surface-container": "#edeeef",
                        "on-surface": "#191c1d",
                        "on-error-container": "#93000a",
                        "background": "#f8f9fa",
                        "outline": "#8c7166"
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                    spacing: { "sm": "12px", "md": "24px", "gutter": "24px", "xs": "4px", "xl": "80px", "lg": "48px", "base": "8px" },
                    fontFamily: {
                        "headline-md": ["Plus Jakarta Sans"],
                        "body-md": ["Be Vietnam Pro"],
                        "label-sm": ["Be Vietnam Pro"],
                        "label-md": ["Be Vietnam Pro"],
                        "display-lg": ["Plus Jakarta Sans"]
                    },
                    fontSize: {
                        "headline-md": ["24px", { "lineHeight": "1.3", "fontWeight": "700" }],
                        "body-md": ["16px", { "lineHeight": "1.5", "fontWeight": "400" }],
                        "label-sm": ["12px", { "lineHeight": "1.2", "fontWeight": "500" }],
                        "label-md": ["14px", { "lineHeight": "1.2", "letterSpacing": "0.01em", "fontWeight": "600" }],
                        "display-lg": ["48px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "800" }]
                    }
                }
            }
        };
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .login-bg-overlay { background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.8)); }
        .cinematic-shadow { box-shadow: 0px 4px 20px rgba(38, 95, 162, 0.1); }
    </style>
</head>
<body class="bg-surface font-body-md text-on-surface">
    <main class="min-h-screen flex items-center justify-center py-lg">
        <!-- Background -->
        <div class="absolute inset-0 z-0 overflow-hidden">
            <img alt="" class="w-full h-full object-cover"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuBqJjSqzDUw1cfaWFnEJgv1fx7bA1u2VNSxXf6cAddhDvzDr-uySr3my1_vyPEIh6nSs7po-Du71asopYkQy8cOVwTTNldjmJUcfXG3yAg9RKf7XyTcYndvsFZ6VH5gTWE-gGStHzPklnMA8Z-3fnb2upPbxhqOCgNkdDYcI2G8Q8YI1slq3FKAKtpWpB2m0W9Bd-fu1cbs6XiTTQdbVAXYGgQV8l8_l34XJJXoXtQM0ejvcls3ObnScLth3hmj4wawLaMgS5Xe6SU" />
            <div class="absolute inset-0 login-bg-overlay"></div>
        </div>
        <!-- Login Card -->
        <div class="relative z-10 w-full max-w-md px-gutter md:px-0">
            <div class="bg-surface-container-lowest rounded-xl p-8 cinematic-shadow border border-outline-variant/10">
                <div class="text-center mb-7">
                    <div class="font-display-lg text-[36px] leading-none font-extrabold tracking-tight text-primary-container mb-2">CineStar</div>
                    <h1 class="font-headline-md text-[22px] font-bold text-on-surface mb-1">Chào Mừng Trở Lại</h1>
                    <p class="font-body-md text-[15px] text-on-surface-variant">Đăng nhập để đặt vé và nhận ưu đãi</p>
                </div>

                <form asp-action="Login" method="post" class="space-y-5">
                    <input type="hidden" asp-for="ReturnUrl" />

                    @if (summaryErrors != null && summaryErrors.Count > 0)
                    {
                        <div id="loginError" class="bg-error-container text-on-error-container rounded-lg px-md py-sm flex items-center gap-xs text-label-md">
                            <span class="material-symbols-outlined text-[20px]">error</span>
                            <span>@summaryErrors[0].ErrorMessage</span>
                        </div>
                    }

                    <!-- Email -->
                    <div class="space-y-2">
                        <label asp-for="Email" class="font-label-md text-label-md text-on-surface-variant block">Email</label>
                        <div class="relative">
                            <span class="material-symbols-outlined text-[20px] absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">person</span>
                            <input asp-for="Email" autocomplete="username" placeholder="example@gmail.com"
                                   class="w-full pl-11 pr-4 py-3 bg-surface-container rounded-lg border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" />
                        </div>
                        <span asp-validation-for="Email" class="text-error text-label-sm block"></span>
                    </div>

                    <!-- Password -->
                    <div class="space-y-2">
                        <label asp-for="Password" class="font-label-md text-label-md text-on-surface-variant block">Mật khẩu</label>
                        <div class="relative">
                            <span class="material-symbols-outlined text-[20px] absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
                            <input asp-for="Password" autocomplete="current-password" placeholder="••••••••"
                                   class="w-full pl-11 pr-11 py-3 bg-surface-container rounded-lg border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" />
                            <button id="togglePassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary" type="button">
                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-error text-label-sm block"></span>
                    </div>

                    <!-- Helpers -->
                    <div class="flex items-center justify-between">
                        <label class="flex items-center gap-xs cursor-pointer group">
                            <input asp-for="RememberMe" class="w-4 h-4 rounded text-primary focus:ring-primary border-outline-variant cursor-pointer" />
                            <span class="font-label-sm text-label-sm text-on-surface-variant group-hover:text-on-surface transition-colors">Ghi nhớ đăng nhập</span>
                        </label>
                        <a class="font-label-sm text-label-sm text-primary hover:underline font-bold" href="#">Quên mật khẩu?</a>
                    </div>

                    <!-- Submit -->
                    <button class="w-full bg-primary-container text-on-primary py-3 rounded-lg font-headline-md text-[16px] font-bold hover:scale-[1.01] active:scale-[0.99] transition-all duration-200 shadow-lg shadow-primary-container/30 mt-1" type="submit">
                        Đăng Nhập
                    </button>
                </form>

                <!-- Divider -->
                <div class="relative my-6">
                    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-outline-variant/30"></div></div>
                    <div class="relative flex justify-center text-label-sm uppercase tracking-wide">
                        <span class="bg-surface-container-lowest px-3 text-on-surface-variant">Hoặc đăng nhập với</span>
                    </div>
                </div>

                <!-- Social Login -->
                <button type="button" class="flex items-center justify-center gap-3 py-3 bg-surface-container-lowest border border-outline-variant/40 rounded-lg hover:bg-surface-container-low hover:border-outline-variant/60 transition-all duration-200 shadow-sm active:scale-[0.99] w-full">
                    <svg class="w-5 h-5" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
                    </svg>
                    <span class="font-label-md text-label-md text-on-surface font-semibold">Tiếp tục với Google</span>
                </button>

                <!-- Register CTA -->
                <div class="mt-6 text-center">
                    <p class="font-body-md text-[15px] text-on-surface-variant">
                        Chưa có tài khoản?
                        <a class="text-primary font-bold hover:underline ml-1" href="#">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Micro-interactions for form focus effects
        document.querySelectorAll('input[type="text"], input[type="email"], input[type="password"]').forEach(input => {
            input.addEventListener('focus', () => input.parentElement.classList.add('scale-[1.01]', 'transition-transform'));
            input.addEventListener('blur', () => input.parentElement.classList.remove('scale-[1.01]'));
        });

        // Tự động xoá thông báo lỗi khi người dùng nhập thông tin hợp lệ (không cần submit)
        (function () {
            const emailInput = document.querySelector('[name="Email"]');
            const passwordInput = document.querySelector('[name="Password"]');
            const emailError = document.querySelector('[data-valmsg-for="Email"]');
            const passwordError = document.querySelector('[data-valmsg-for="Password"]');
            const loginError = document.getElementById('loginError');
            const emailRegex = /^[^\s\x40]+\x40[^\s\x40]+\.[^\s\x40]+$/;

            function clearFieldError(span) {
                if (span) { span.textContent = ''; }
            }

            function hideLoginError() {
                if (loginError) { loginError.style.display = 'none'; }
            }

            if (emailInput) {
                emailInput.addEventListener('input', () => {
                    hideLoginError();
                    if (emailRegex.test(emailInput.value.trim())) {
                        clearFieldError(emailError);
                    }
                });
            }

            if (passwordInput) {
                passwordInput.addEventListener('input', () => {
                    hideLoginError();
                    if (passwordInput.value.length > 0) {
                        clearFieldError(passwordError);
                    }
                });
            }
        })();

        // Toggle password visibility
        const togglePass = document.getElementById('togglePassword');
        if (togglePass) {
            togglePass.addEventListener('click', () => {
                const passInput = togglePass.parentElement.querySelector('input');
                const icon = togglePass.querySelector('.material-symbols-outlined');
                if (passInput.type === 'password') {
                    passInput.type = 'text';
                    icon.textContent = 'visibility_off';
                } else {
                    passInput.type = 'password';
                    icon.textContent = 'visibility';
                }
            });
        }
    </script>
</body>
</html>
