@model SeatTypeFormViewModel
@{
    ViewData["Title"] = "Sửa Loại Ghế";
}

@section Styles {
    <style>
        .sf-wrap { max-width: 560px; margin: 6rem auto 3rem; padding: 0 1.5rem; }
        .sf-title { font-family: var(--font-head); font-size: 1.6rem; font-weight: 800; color: var(--on-surface); margin-bottom: 1.5rem; }
        .sf-card { background: var(--white); border-radius: var(--radius-xl); box-shadow: var(--shadow-sm); padding: 1.75rem; }
        .sf-field { margin-bottom: 1.1rem; }
        .sf-field label { display: block; font-weight: 600; color: var(--on-surface-variant); margin-bottom: .4rem; font-size: .9rem; }
        .sf-field input { width: 100%; padding: .6rem .8rem; border: 1px solid var(--outline-variant); border-radius: var(--radius); background: var(--white); font-family: var(--font-body); }
        .sf-field input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(243,112,33,.15); }
        .sf-hint { color: var(--on-surface-variant); font-size: .82rem; margin-top: .35rem; }
        .sf-error { color: #b91c1c; font-size: .82rem; margin-top: .3rem; display: block; }
        .sf-summary { color: #b91c1c; font-size: .9rem; margin-bottom: 1rem; }
        .sf-actions { display: flex; gap: .75rem; margin-top: 1.5rem; }
        .sf-btn { padding: .6rem 1.3rem; border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; font-family: var(--font-body); text-decoration: none; display: inline-flex; align-items: center; }
        .sf-btn-primary { background: var(--primary); color: var(--white); }
        .sf-btn-primary:hover { background: var(--primary-dark); }
        .sf-btn-ghost { background: var(--surface-container); color: var(--on-surface); }
    </style>
}

<div class="sf-wrap">
    <h1 class="sf-title">Sửa Loại Ghế</h1>

    <div class="sf-card">
        <form method="post" action="@Url.Action("Edit", "SeatsType", new { id = Model.Id })">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="sf-summary"></div>

            <div class="sf-field">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="sf-error"></span>
            </div>

            <div class="sf-field">
                <label asp-for="Capacity"></label>
                <input asp-for="Capacity" type="number" min="1" max="10" />
                <span asp-validation-for="Capacity" class="sf-error"></span>
                <p class="sf-hint">Số người ngồi: ghế thường = 1, ghế đôi = 2, ghế ba = 3.</p>
            </div>

            <div class="sf-field">
                <label asp-for="ColumnSpan"></label>
                <input asp-for="ColumnSpan" type="number" min="1" max="10" />
                <span asp-validation-for="ColumnSpan" class="sf-error"></span>
                <p class="sf-hint">Số ô loại ghế này chiếm trên sơ đồ ghế (thường bằng sức chứa).</p>
            </div>

            <div class="sf-actions">
                <button type="submit" class="sf-btn sf-btn-primary">Lưu thay đổi</button>
                <a class="sf-btn sf-btn-ghost" href="@Url.Action("Index", "SeatsType")">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
