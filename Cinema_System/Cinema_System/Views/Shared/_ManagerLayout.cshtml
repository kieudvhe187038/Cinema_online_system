<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineStar</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        body { background: #f4f6f8; overflow-x: hidden; }

        /* ── Sidebar ── */
        .mgr-sidebar {
            position: fixed; top: 0; left: 0; bottom: 0; width: 240px;
            background: #fff; border-right: 1px solid #e8eaed;
            display: flex; flex-direction: column; z-index: 100;
        }
        .mgr-logo-area {
            padding: 1.25rem 1.5rem 1rem;
            border-bottom: 1px solid #f0f0f0;
            flex-shrink: 0;
        }
        .mgr-logo-name {
            font-family: var(--font-head); font-size: 1.5rem;
            font-weight: 800; color: var(--primary); letter-spacing: -.5px; line-height: 1;
        }
        .mgr-logo-sub {
            font-size: .7rem; color: #8a94a6; margin-top: .2rem;
            font-weight: 500; text-transform: uppercase; letter-spacing: .5px;
        }
        .mgr-nav { flex: 1; padding: .75rem 0; overflow-y: auto; }
        .mgr-nav-section {
            padding: .6rem 1.25rem .25rem;
            font-size: .68rem; font-weight: 700; color: #9ca3af;
            text-transform: uppercase; letter-spacing: .6px;
        }
        .mgr-nav-item {
            display: flex; align-items: center; gap: .7rem;
            padding: .6rem 1rem; margin: .1rem .75rem;
            border-radius: .5rem; color: #374151;
            text-decoration: none; font-size: .875rem; font-weight: 500;
            transition: background .15s, color .15s;
        }
        .mgr-nav-item:hover { background: #fff7f0; color: var(--primary); }
        .mgr-nav-item.active { background: var(--primary); color: #fff; }
        .mgr-nav-item .material-symbols-outlined { font-size: 20px; flex-shrink: 0; }
        .mgr-nav-sep { margin: .5rem 1.25rem; border: none; border-top: 1px solid #f0f0f0; }
        .mgr-sidebar-footer {
            padding: 1rem 1.25rem; border-top: 1px solid #f0f0f0; flex-shrink: 0;
        }
        .mgr-new-btn {
            display: flex; align-items: center; justify-content: center; gap: .4rem;
            width: 100%; padding: .65rem; background: var(--primary); color: #fff;
            border: none; border-radius: .6rem; font-family: var(--font-body);
            font-size: .875rem; font-weight: 600; cursor: pointer;
            text-decoration: none; transition: background .15s;
        }
        .mgr-new-btn:hover { background: var(--primary-dark); color: #fff; }
        .mgr-new-btn .material-symbols-outlined { font-size: 18px; }

        /* ── Topbar ── */
        .mgr-topbar {
            position: fixed; top: 0; left: 240px; right: 0; height: 60px;
            background: #fff; border-bottom: 1px solid #e8eaed;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 1.75rem; z-index: 90;
        }
        .mgr-topbar-title {
            font-family: var(--font-head); font-size: 1.05rem;
            font-weight: 700; color: var(--secondary-dark); letter-spacing: .3px;
        }
        .mgr-topbar-right { display: flex; align-items: center; gap: .6rem; }
        .mgr-icon-btn {
            width: 36px; height: 36px; border: none; background: #f4f6f8;
            border-radius: 50%; cursor: pointer; color: #374151;
            display: flex; align-items: center; justify-content: center;
            position: relative; transition: background .15s;
        }
        .mgr-icon-btn:hover { background: #ffe8d6; color: var(--primary); }
        .mgr-icon-btn .material-symbols-outlined { font-size: 20px; }
        .mgr-notif-dot {
            position: absolute; top: 7px; right: 7px;
            width: 7px; height: 7px; border-radius: 50%;
            background: #ef4444; border: 1.5px solid #fff;
        }
   
        

        /* ── Main content ── */
        .mgr-content { margin-left: 240px; padding-top: 60px; min-height: 100vh; }
        .mgr-page { padding: 1.75rem; }
    </style>
</head>
<body>
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var newUrl  = ViewData["SidebarNewUrl"]?.ToString();
    var newLabel = ViewData["SidebarNewLabel"]?.ToString() ?? "Thêm mới";
    var topTitle = ViewData["Title"]?.ToString() ?? "Quản Lý";
}

<!-- Sidebar -->
<aside class="mgr-sidebar">
    <div class="mgr-logo-area">
        <div class="mgr-logo-name">CineStar</div>
        <div class="mgr-logo-sub">Theater Manager</div>
    </div>

    <nav class="mgr-nav">
        <a class="mgr-nav-item" href="#">
            <span class="material-symbols-outlined">grid_view</span>
            <span>Dashboard</span>
        </a>
        <a class="mgr-nav-item @(ctrl == "MovieManagement" ? "active" : "")"
           asp-controller="MovieManagement" asp-action="Index">
            <span class="material-symbols-outlined">movie</span>
            <span>Movie Catalog</span>
        </a>
        <a class="mgr-nav-item" href="#">
            <span class="material-symbols-outlined">schedule</span>
            <span>Showtimes</span>
        </a>
        <a class="mgr-nav-item" href="#">
            <span class="material-symbols-outlined">confirmation_number</span>
            <span>Bookings</span>
        </a>
        <hr class="mgr-nav-sep" />
        <a class="mgr-nav-item @(ctrl == "FoodBeverages" ? "active" : "")"
           asp-controller="FoodBeverages" asp-action="Index">
            <span class="material-symbols-outlined">restaurant</span>
            <span>Đồ Ăn &amp; Thức Uống</span>
        </a>
        <a class="mgr-nav-item" href="#">
            <span class="material-symbols-outlined">settings</span>
            <span>Settings</span>
        </a>
    </nav>

    @if (!string.IsNullOrEmpty(newUrl))
    {
        <div class="mgr-sidebar-footer">
            <a class="mgr-new-btn" href="@newUrl">
                <span class="material-symbols-outlined">add</span>
                @newLabel
            </a>
        </div>
    }
</aside>

<!-- Topbar -->
<header class="mgr-topbar">
    <span class="mgr-topbar-title">@topTitle</span>
    <div class="mgr-topbar-right">
        <button class="mgr-icon-btn">
            <span class="material-symbols-outlined">notifications</span>
            <span class="mgr-notif-dot"></span>
        </button>
        <button class="mgr-icon-btn">
            <span class="material-symbols-outlined">help</span>
        </button>
        
    </div>
</header>

<!-- Main -->
<div class="mgr-content">
    <main class="mgr-page">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
