<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineStar</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">

    <!-- Tailwind CSS (Play CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#f37021',
                        'primary-dark': '#c95a10',
                        secondary: '#004b8d',
                        'secondary-dark': '#001c3a',
                    },
                    fontFamily: {
                        head: ['"Plus Jakarta Sans"', 'sans-serif'],
                        body: ['"Be Vietnam Pro"', 'sans-serif'],
                    },
                },
            },
        };
    </script>
    <style>
        body { font-family: 'Be Vietnam Pro', sans-serif; }
        .material-symbols-outlined { font-size: 20px; line-height: 1; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-[#f4f6f8] overflow-x-hidden text-[#191c1d]">
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var newUrl  = ViewData["SidebarNewUrl"]?.ToString();
    var newLabel = ViewData["SidebarNewLabel"]?.ToString() ?? "Thêm mới";
    var topTitle = ViewData["Title"]?.ToString() ?? "Quản Lý";

    const string navBase = "flex items-center gap-3 px-4 py-2.5 mx-3 my-0.5 rounded-lg text-sm font-medium transition-colors";
    const string navIdle = "text-gray-700 hover:bg-[#fff7f0] hover:text-primary";
    const string navActive = "bg-primary text-white";
}

<!-- Sidebar -->
<aside class="fixed inset-y-0 left-0 w-60 bg-white border-r border-[#e8eaed] flex flex-col z-[100]">
    <div class="px-6 pt-5 pb-4 border-b border-[#f0f0f0] shrink-0">
        <div class="font-head text-2xl font-extrabold text-primary tracking-tight leading-none">CineStar</div>
        <div class="text-[.7rem] text-[#8a94a6] mt-0.5 font-medium uppercase tracking-wide">Theater Manager</div>
    </div>

    <nav class="flex-1 py-3 overflow-y-auto">
        <a class="@navBase @navIdle" href="#">
            <span class="material-symbols-outlined">grid_view</span>
            <span>Dashboard</span>
        </a>
        <a class="@navBase @(ctrl == "MovieManagement" ? navActive : navIdle)"
           asp-controller="MovieManagement" asp-action="Index">
            <span class="material-symbols-outlined">movie</span>
            <span>Movie Catalog</span>
        </a>
        <a class="@navBase @navIdle" href="#">
            <span class="material-symbols-outlined">schedule</span>
            <span>Showtimes</span>
        </a>
        <a class="@navBase @navIdle" href="#">
            <span class="material-symbols-outlined">confirmation_number</span>
            <span>Bookings</span>
        </a>
        <hr class="my-2 mx-6 border-t border-[#f0f0f0]" />
        <a class="@navBase @(ctrl == "FoodBeverages" ? navActive : navIdle)"
           asp-controller="FoodBeverages" asp-action="Index">
            <span class="material-symbols-outlined">restaurant</span>
            <span>Đồ Ăn &amp; Thức Uống</span>
        </a>
        <a class="@navBase @navIdle" href="#">
            <span class="material-symbols-outlined">settings</span>
            <span>Settings</span>
        </a>
    </nav>

    @if (!string.IsNullOrEmpty(newUrl))
    {
        <div class="px-5 py-4 border-t border-[#f0f0f0] shrink-0">
            <a class="flex items-center justify-center gap-1.5 w-full py-2.5 bg-primary hover:bg-primary-dark text-white rounded-lg text-sm font-semibold transition-colors"
               href="@newUrl">
                <span class="material-symbols-outlined" style="font-size:18px">add</span>
                @newLabel
            </a>
        </div>
    }
</aside>

<!-- Topbar -->
<header class="fixed top-0 left-60 right-0 h-[60px] bg-white border-b border-[#e8eaed] flex items-center justify-between px-7 z-[90]">
    <span class="font-head text-[1.05rem] font-bold text-secondary-dark tracking-wide">@topTitle</span>
    <div class="flex items-center gap-2.5">
        <button class="relative w-9 h-9 rounded-full bg-[#f4f6f8] hover:bg-[#ffe8d6] text-gray-700 hover:text-primary flex items-center justify-center transition-colors">
            <span class="material-symbols-outlined">notifications</span>
            <span class="absolute top-[7px] right-[7px] w-[7px] h-[7px] rounded-full bg-red-500 border-[1.5px] border-white"></span>
        </button>
        <button class="w-9 h-9 rounded-full bg-[#f4f6f8] hover:bg-[#ffe8d6] text-gray-700 hover:text-primary flex items-center justify-center transition-colors">
            <span class="material-symbols-outlined">help</span>
        </button>
    </div>
</header>

<!-- Main -->
<div class="ml-60 pt-[60px] min-h-screen">
    <main class="p-7">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
