@model RoomTypeFormViewModel
@{
    ViewData["Title"] = "Sửa Loại Phòng";
}

@section Styles {
    <style>
        .rf-wrap { max-width: 560px; margin: 6rem auto 3rem; padding: 0 1.5rem; }
        .rf-title { font-family: var(--font-head); font-size: 1.6rem; font-weight: 800; color: var(--on-surface); margin-bottom: 1.5rem; }
        .rf-card { background: var(--white); border-radius: var(--radius-xl); box-shadow: var(--shadow-sm); padding: 1.75rem; }
        .rf-field { margin-bottom: 1.1rem; }
        .rf-field label { display: block; font-weight: 600; color: var(--on-surface-variant); margin-bottom: .4rem; font-size: .9rem; }
        .rf-field input, .rf-field textarea { width: 100%; padding: .6rem .8rem; border: 1px solid var(--outline-variant); border-radius: var(--radius); background: var(--white); font-family: var(--font-body); }
        .rf-field textarea { min-height: 90px; resize: vertical; }
        .rf-field input:focus, .rf-field textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(243,112,33,.15); }
        .rf-error { color: #b91c1c; font-size: .82rem; margin-top: .3rem; display: block; }
        .rf-summary { color: #b91c1c; font-size: .9rem; margin-bottom: 1rem; }
        .rf-actions { display: flex; gap: .75rem; margin-top: 1.5rem; }
        .rf-btn { padding: .6rem 1.3rem; border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; font-family: var(--font-body); text-decoration: none; display: inline-flex; align-items: center; }
        .rf-btn-primary { background: var(--primary); color: var(--white); }
        .rf-btn-primary:hover { background: var(--primary-dark); }
        .rf-btn-ghost { background: var(--surface-container); color: var(--on-surface); }
    </style>
}

<div class="rf-wrap">
    <h1 class="rf-title">Sửa Loại Phòng</h1>

    <div class="rf-card">
        <form method="post" action="@Url.Action("Edit", "RoomTypes", new { id = Model.Id })">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="rf-summary"></div>

            <div class="rf-field">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="rf-error"></span>
            </div>

            <div class="rf-field">
                <label asp-for="Description"></label>
                <textarea asp-for="Description"></textarea>
                <span asp-validation-for="Description" class="rf-error"></span>
            </div>

            <div class="rf-actions">
                <button type="submit" class="rf-btn rf-btn-primary">Lưu thay đổi</button>
                <a class="rf-btn rf-btn-ghost" href="@Url.Action("Index", "RoomTypes")">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
