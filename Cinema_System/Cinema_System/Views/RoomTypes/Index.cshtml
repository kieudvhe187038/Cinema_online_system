@model IEnumerable<RoomTypeDTO>
@{
    ViewData["Title"] = "Quản Lý Loại Phòng";
}

@section Styles {
    <style>
        .rt-wrap { max-width: 1000px; margin: 6rem auto 3rem; padding: 0 1.5rem; }
        .rt-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
        .rt-title { font-family: var(--font-head); font-size: 1.6rem; font-weight: 800; color: var(--on-surface); }
        .rt-alert { padding: .75rem 1rem; border-radius: var(--radius); margin-bottom: 1rem; font-size: .9rem; }
        .rt-alert.success { background: #e7f5ec; color: #166534; border: 1px solid #16653433; }
        .rt-alert.error { background: #fde8e8; color: #b91c1c; border: 1px solid #b91c1c33; }
        .rt-btn { padding: .55rem 1.1rem; border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; font-family: var(--font-body); text-decoration: none; display: inline-flex; align-items: center; gap: .35rem; }
        .rt-btn-primary { background: var(--primary); color: var(--white); }
        .rt-btn-primary:hover { background: var(--primary-dark); }
        .rt-table { width: 100%; border-collapse: collapse; background: var(--white); border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-sm); }
        .rt-table th, .rt-table td { padding: .85rem 1rem; text-align: left; border-bottom: 1px solid var(--surface-container); font-size: .9rem; vertical-align: top; }
        .rt-table th { background: var(--secondary-dark); color: var(--white); font-weight: 600; }
        .rt-table tr:hover td { background: var(--surface); }
        .rt-name { font-weight: 600; color: var(--on-surface); }
        .rt-desc { color: var(--on-surface-variant); max-width: 380px; }
        .rt-tag { display: inline-block; padding: .15rem .55rem; border-radius: 999px; font-size: .75rem; font-weight: 600; background: var(--surface-container); color: var(--on-surface-variant); }
        .rt-actions { display: flex; gap: .5rem; align-items: center; }
        .rt-link { color: var(--secondary); text-decoration: none; font-weight: 600; font-size: .85rem; }
        .rt-link:hover { color: var(--primary); }
        .rt-danger { color: #b91c1c; background: none; border: none; cursor: pointer; font-weight: 600; font-size: .85rem; font-family: var(--font-body); padding: 0; }
        .rt-disabled { color: var(--on-surface-variant); font-size: .8rem; font-style: italic; }
        .rt-empty { text-align: center; padding: 3rem; color: var(--on-surface-variant); }
    </style>
}

<div class="rt-wrap">
    <div class="rt-top">
        <h1 class="rt-title">Quản Lý Loại Phòng</h1>
        <a class="rt-btn rt-btn-primary" href="@Url.Action("Create", "RoomTypes")">+ Thêm loại phòng</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="rt-alert success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rt-alert error">@TempData["Error"]</div>
    }

    @if (Model.Any())
    {
        <table class="rt-table">
            <thead>
                <tr>
                    <th>Tên loại phòng</th>
                    <th>Mô tả</th>
                    <th>Số phòng đang dùng</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="rt-name">@item.Name</span></td>
                        <td><span class="rt-desc">@(string.IsNullOrEmpty(item.Description) ? "—" : item.Description)</span></td>
                        <td><span class="rt-tag">@item.RoomCount phòng</span></td>
                        <td>
                            <div class="rt-actions">
                                <a class="rt-link" href="@Url.Action("Edit", "RoomTypes", new { id = item.Id })">Sửa</a>
                                @if (item.InUse)
                                {
                                    <span class="rt-disabled" title="Đang được phòng hoặc cấu hình giá sử dụng">Không thể xóa</span>
                                }
                                else
                                {
                                    <form method="post" action="@Url.Action("Delete", "RoomTypes", new { id = item.Id })" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="rt-danger"
                                                onclick="return confirm('Xóa loại phòng @item.Name?');">Xóa</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="rt-empty">Chưa có loại phòng nào. Bấm "Thêm loại phòng" để tạo mới.</div>
    }
</div>
